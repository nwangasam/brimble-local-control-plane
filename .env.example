# API runtime
HOST=0.0.0.0
PORT=3001
PIPELINE_MODE=live
CORS_ORIGIN=*

# Local storage
DATA_DIR=/data
DATABASE_PATH=/data/sqlite/app.db
UPLOADS_DIR=/data/uploads
WORKSPACES_DIR=/data/workspaces

# Caddy integration
CADDY_GENERATED_DIR=/caddy-generated
CADDY_PUBLIC_BASE_URL=http://caddy
CADDY_RELOAD_COMMAND=docker exec brimble-caddy caddy reload --config /etc/caddy/Caddyfile --adapter caddyfile

# Deployment runtime
DEPLOYMENT_TARGET_PORT=3000
DOCKER_NETWORK=brimble
DOCKER_BIN=docker

# Source preparation
GIT_BIN=git
UNZIP_BIN=unzip

# Build tooling
RAILPACK_BIN=railpack
BUILDKIT_HOST=tcp://buildkit:1234

# Verifier overrides
BRIMBLE_BASE_URL=http://127.0.0.1:8080
BRIMBLE_TEST_GIT_URL=https://github.com/heroku/node-js-getting-started
BRIMBLE_SAMPLE_APP_DIR=sample-apps/hello-node
BRIMBLE_DEPLOY_TIMEOUT_MS=720000
BRIMBLE_POLL_INTERVAL_MS=5000
BRIMBLE_PRECHECK_TIMEOUT_MS=60000
