{
  "name": "@brimble/api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @brimble/contracts build && tsx watch src/server.ts",
    "build": "pnpm --filter @brimble/contracts build && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "pnpm --filter @brimble/contracts build && tsc -p tsconfig.json --noEmit",
    "test": "pnpm --filter @brimble/contracts build && tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@brimble/contracts": "workspace:*",
    "@fastify/cors": "^11.1.0",
    "@fastify/multipart": "^9.2.1",
    "@libsql/client": "^0.17.3",
    "drizzle-orm": "^0.44.5",
    "fastify": "^5.6.1"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
